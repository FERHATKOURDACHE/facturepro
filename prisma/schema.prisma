generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  ACCOUNTANT
  MEMBER
  READ_ONLY
}

enum VatRegime {
  FRANCHISE_BASE
  TVA_STANDARD
  TVA_REDUCED
  EXEMPT
}

enum UrssafActivity {
  SALE_BIC
  SERVICE_BIC
  SERVICE_BNC
  CIPAV
  CUSTOM
}

enum MissionStatus {
  DRAFT
  VALIDATED
  INVOICED
  PAID
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  READY
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  CASH
  CHECK
  OTHER
}

enum ExpenseType {
  FUEL
  PARKING
  MEAL
  TRANSPORT
  MATERIAL
  OTHER
}

enum UnitType {
  HOUR
  DAY
  UNIT
  FIXED_PRICE
}

enum DocumentType {
  INVOICE
  TIMESHEET
  QUOTE
  RECEIPT
  URSSAF_REPORT
  EXPORT
}

enum ExportFormat {
  PDF
  XLSX
  CSV
  JSON
}

enum AiActionType {
  INVOICE_DRAFT
  TIMESHEET_EXTRACTION
  EXPENSE_CLASSIFICATION
  EMAIL_DRAFT
  URSSAF_EXPLANATION
  DOCUMENT_REVIEW
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  name           String?
  passwordHash   String?
  memberships    Membership[]
  aiGenerations  AiGeneration[]
  auditLogs      AuditLog[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Organization {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  country             String               @default("FR")
  currency            String               @default("EUR")
  memberships         Membership[]
  profiles            CompanyProfile[]
  clients             Client[]
  missions            Mission[]
  expenses            Expense[]
  invoices            Invoice[]
  payments            Payment[]
  documents           DocumentExport[]
  urssafDeclarations  UrssafDeclaration[]
  aiGenerations       AiGeneration[]
  auditLogs           AuditLog[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Membership {
  id              String        @id @default(cuid())
  userId          String
  organizationId  String
  role            UserRole      @default(OWNER)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model CompanyProfile {
  id                   String         @id @default(cuid())
  organizationId        String
  legalName             String
  tradeName             String?
  addressLine1          String
  addressLine2          String?
  postalCode            String
  city                  String
  country               String         @default("FR")
  siren                 String?
  siret                 String?
  ape                   String?
  vatNumber             String?
  email                 String?
  phone                 String?
  iban                  String?
  bic                   String?
  vatRegime             VatRegime      @default(FRANCHISE_BASE)
  invoiceLegalNotice    String         @default("TVA non applicable - article 293 B du CGI")
  defaultHourlyRate     Decimal        @default(13.00) @db.Decimal(10, 2)
  urssafActivity        UrssafActivity @default(SERVICE_BNC)
  urssafRate            Decimal        @default(0.2560) @db.Decimal(6, 4)
  isDefault             Boolean        @default(false)
  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices              Invoice[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([organizationId])
}

model Client {
  id                String        @id @default(cuid())
  organizationId    String
  legalName         String
  contactName       String?
  email             String?
  phone             String?
  addressLine1      String
  addressLine2      String?
  postalCode        String?
  city              String?
  country           String        @default("FR")
  siren             String?
  siret             String?
  ape               String?
  vatNumber         String?
  paymentTermsDays  Int           @default(30)
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  missions          Mission[]
  invoices          Invoice[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([organizationId])
  @@index([siret])
}

model Mission {
  id              String         @id @default(cuid())
  organizationId  String
  clientId        String
  invoiceId       String?
  date            DateTime
  startTime       DateTime
  endTime         DateTime
  breakMinutes    Int            @default(0)
  title           String
  locationName    String?
  address         String?
  hourlyRate      Decimal        @db.Decimal(10, 2)
  quantityHours   Decimal        @db.Decimal(8, 2)
  status          MissionStatus  @default(DRAFT)
  notes           String?
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client          Client         @relation(fields: [clientId], references: [id])
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id])
  expenses        Expense[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId, date])
  @@index([clientId])
  @@index([invoiceId])
}

model Expense {
  id              String        @id @default(cuid())
  organizationId  String
  missionId       String?
  invoiceId       String?
  type            ExpenseType   @default(OTHER)
  label           String
  amount          Decimal       @db.Decimal(10, 2)
  expenseDate     DateTime?
  notes           String?
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mission         Mission?      @relation(fields: [missionId], references: [id])
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id])
  createdAt       DateTime      @default(now())

  @@index([organizationId])
  @@index([invoiceId])
  @@index([missionId])
}

model Invoice {
  id                   String          @id @default(cuid())
  organizationId        String
  profileId             String?
  clientId              String
  number                String
  issueDate             DateTime
  dueDate               DateTime?
  periodStart           DateTime?
  periodEnd             DateTime?
  status                InvoiceStatus   @default(DRAFT)
  currency              String          @default("EUR")
  subtotal              Decimal         @default(0.00) @db.Decimal(12, 2)
  vatRate               Decimal         @default(0.0000) @db.Decimal(6, 4)
  vatAmount             Decimal         @default(0.00) @db.Decimal(12, 2)
  total                 Decimal         @default(0.00) @db.Decimal(12, 2)
  paidHoursDeduction    Decimal         @default(0.00) @db.Decimal(8, 2)
  paidAmountDeduction   Decimal         @default(0.00) @db.Decimal(12, 2)
  notes                 String?
  legalNotice           String?
  pdfUrl                String?
  xlsxUrl               String?
  organization          Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  profile               CompanyProfile? @relation(fields: [profileId], references: [id])
  client                Client          @relation(fields: [clientId], references: [id])
  lines                 InvoiceLine[]
  missions              Mission[]
  expenses              Expense[]
  payments              Payment[]
  documents             DocumentExport[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId, issueDate])
  @@index([clientId])
}

model InvoiceLine {
  id          String    @id @default(cuid())
  invoiceId   String
  label       String
  description String?
  quantity    Decimal   @db.Decimal(10, 2)
  unit        UnitType   @default(HOUR)
  unitPrice   Decimal   @db.Decimal(10, 2)
  vatRate     Decimal   @default(0.0000) @db.Decimal(6, 4)
  total       Decimal   @db.Decimal(12, 2)
  lineOrder   Int       @default(0)
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id              String         @id @default(cuid())
  organizationId  String
  invoiceId       String
  amount          Decimal        @db.Decimal(12, 2)
  method          PaymentMethod  @default(BANK_TRANSFER)
  paidAt          DateTime
  reference       String?
  notes           String?
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice         Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@index([organizationId])
  @@index([invoiceId])
}

model UrssafDeclaration {
  id                    String          @id @default(cuid())
  organizationId         String
  year                  Int
  month                 Int?
  quarter               Int?
  periodStart           DateTime
  periodEnd             DateTime
  activity              UrssafActivity
  turnover              Decimal         @db.Decimal(12, 2)
  contributionRate      Decimal         @db.Decimal(6, 4)
  contributionAmount    Decimal         @db.Decimal(12, 2)
  cfpRate               Decimal?        @db.Decimal(6, 4)
  cfpAmount             Decimal?        @db.Decimal(12, 2)
  sourceLabel           String?
  notes                 String?
  organization          Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([organizationId, year])
}

model DocumentExport {
  id              String        @id @default(cuid())
  organizationId  String
  invoiceId       String?
  documentType    DocumentType
  format          ExportFormat
  fileName        String
  storageKey      String?
  generatedAt     DateTime      @default(now())
  checksum        String?
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([invoiceId])
}

model AiGeneration {
  id              String        @id @default(cuid())
  organizationId  String
  userId          String?
  type            AiActionType
  prompt          String
  response        String?
  inputJson       Json?
  outputJson      Json?
  model           String?
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())

  @@index([organizationId])
  @@index([userId])
}

model AuditLog {
  id              String        @id @default(cuid())
  organizationId  String
  userId          String?
  action          String
  entityType      String
  entityId        String?
  metadata        Json?
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())

  @@index([organizationId])
  @@index([userId])
}
